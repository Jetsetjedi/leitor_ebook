# Variáveis de ambiente — NUNCA commite este arquivo!
# Copie para .env e preencha antes de rodar a aplicação.

# Chave secreta para sessões Flask (gere com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=troque_por_uma_chave_segura_gerada_aleatoriamente

# Ambiente: development | production
FLASK_ENV=development
